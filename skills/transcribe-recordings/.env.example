# Path to Obsidian vault
VAULT_PATH=/path/to/your/obsidian/vault

# Path to Whisper executable
WHISPER_PATH=/Users/your-user/.local/bin/whisper

# Path to FFmpeg executable
FFMPEG_PATH=/Users/your-user/.local/bin/ffmpeg

# Delete original recordings after transcription (true/false)
DELETE_AFTER_TRANSCRIBE=true

# Enable speaker diarization (true/false)
# When enabled, attempts to identify different speakers as "Speaker A", "Speaker B", etc.
ENABLE_SPEAKER_DIARIZATION=true

# Enable automatic file watching (Phase 2 feature)
AUTO_WATCH_ENABLED=false
